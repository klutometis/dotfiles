[user]
 name = Peter Danenberg
 email = github@pcd.la

[include]
 # For corp-specific setting, e.g. email.
 path = ~/.gitconfig-email

[github]
 user = klutometis

# http://jblevins.org/notes/git-colors
[color]
 pager = false

[alias]
 ci = commit
 co = checkout
 st = status
 sub = submodule
 up = update
 ls = ls-files
 # http://coderwall.com/p/euwpig?i=3&p=1&t=git
 lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

[status]
 relativePaths = false

[credential]
	helper = store
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictStyle = diff3
[diff]
	colorMoved = default

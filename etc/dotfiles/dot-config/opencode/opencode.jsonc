{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "small_model": "anthropic/claude-sonnet-4-6",
  "mcp": {
    // FastMCP gateway: 19 tools (search, scrape, save_memory, calendar, gmail, opencode)
    // Runs on localhost:3100 via start-mcp-gateway (MCP_LOCAL=1)
    "mcp": {
      "type": "remote",
      "url": "http://localhost:3100/mcp",
      "enabled": true
    },
    // Chrome DevTools Protocol — personal Chrome on port 9223
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9223"
      ],
      "enabled": true
    }
  }
}

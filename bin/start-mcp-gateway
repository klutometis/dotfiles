#!/usr/bin/env zsh
# Wrapper to run MCP gateway in local mode via uvx
# Installs latest from git on every launch (only runs once per X session)
# Started automatically from ~/.xinitrc

# Load environment (including nvm, rbenv, pyenv)
source "$HOME/.zshenv"

# Load MCP-specific environment variables (API keys, etc.)
source "$HOME/.env.mcp"

# Run gateway in local mode (no OAuth, localhost only, port 3100)
exec uvx --reinstall --from "git+ssh://git@github.com/klutometis/mcp-gateway.git" gateway-local

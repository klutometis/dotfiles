#!/usr/bin/env bash
#
# vm - open/attach a tmux session on the host named by $VM_HOST
#
# Usage:
#   vm                  attach to default session (scratch)
#   vm SESSION          attach to/create SESSION
#
# Set VM_HOST in any sourced env file (e.g., ~/.env). The script
# refuses to run without it.
#
# Locally this opens a new terminal via ~/bin/terminal --remote.
# When already on $VM_HOST, it just runs `tmux new -A -s SESSION`
# in the current shell.

set -euo pipefail

if [ -z "${VM_HOST:-}" ]; then
  echo "vm: VM_HOST is not set." >&2
  echo "    Set it in ~/.env or another sourced env file, e.g.:" >&2
  echo "      VM_HOST=vm.example.com" >&2
  exit 1
fi

session="${1:-scratch}"

# Are we already on $VM_HOST? Skip the ssh hop.
host_fqdn=$(hostname -f 2>/dev/null || hostname)
if [[ "$host_fqdn" == "$VM_HOST" ]] || [[ "$host_fqdn" == *".$VM_HOST" ]]; then
  exec tmux new -A -s "$session"
fi

exec "$HOME/bin/terminal" --remote "$VM_HOST" "$session"
